#!/usr/bin/env bash
#
# climail/checkmail:
# Iterate over all Maildir folders with unread mail.
#

set -euo pipefail

# shellcheck disable=SC1091
. gettext.sh
export TEXTDOMAIN=climail
for locale_dir in ./po /usr/local/share/locale; do
	if [[ -r "${locale_dir}/de/LC_MESSAGES/climail.mo" ]]; then
		export TEXTDOMAINDIR=$locale_dir
		break
	fi
done

export MAILDIR="${MAILDIR:-/var/mail/${LOGNAME}}"

usage_exit() {
	echo "$(gettext 'Usage'):"
	echo "  $0 [<mailbox_command> [<arguments...>]]"
	echo "  $0 {-l|--list-only}"
	exit "${1:-0}"
}

find_mailboxes_with_unread_mail() {
	find "${MAILDIR}" -type d -not -empty \( -name 'new' -o -name 'cur' \) -print0 |
		xargs -0 -I{} -- find {} -type f -not -regex '.*,D?R?S[a-z]*' -printf '%h\n' |
		sed -E -e 's:^'"${MAILDIR}"'/:+:' -e 's:/?(cur|new)$::' |
		sort -u
}

get_mailbox_name() {
	if [[ "$1" = "+" ]]; then
		echo "INBOX"
	else
		echo "${1#+.}"
	fi
}

unset LIST_ONLY

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	"--list-only"|"-l")
		LIST_ONLY=1 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

if [[ ! -d "${MAILDIR}/cur" ]]; then
	eval_gettext "Error: \"\${MAILDIR}\" not found!" >&2; echo >&2
	exit 1
fi

eval_gettext "Looking for unread mail in \${MAILDIR} ..."; echo

declare -i invocations=0
mapfile -t mailboxes < <(find_mailboxes_with_unread_mail)

if [[ ${#mailboxes[@]} -eq 0 ]]; then
	gettext "No unread mail."; echo
	exit 0
fi

for mailbox in "${mailboxes[@]}"; do
	printf " • \e[1m%s\e[0m\n" "$(get_mailbox_name "$mailbox")"
done

[[ -n "${LIST_ONLY:-}" ]] && exit 0

declare -i exit_code=0
for mailbox in "${mailboxes[@]}"; do
	echo
	invocations=$((invocations + 1))
	"$(dirname "$0")"/openmail "${mailbox}" "$@" && exit_code=0 || exit_code=$?
	[[ $exit_code -eq 0 ]] || break
done
echo

if [[ ${#mailboxes[@]} -ne $invocations ]]; then
	# shellcheck disable=SC2034
	count=${#mailboxes[@]}
	total_info=$(eval_gettext " (out of \${count})")
else
	# shellcheck disable=SC2034
	total_info=""
fi
eval_ngettext \
	"Opened one mailbox\${total_info} with unread mail." \
	"Opened \${invocations} mailboxes\${total_info} with unread mail." \
	$invocations; echo

exit $exit_code
