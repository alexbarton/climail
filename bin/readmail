#!/usr/bin/env bash
#
# climail/readmail:
# Interactively select a mailbox to read mail from.
#

set -euo pipefail

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
export SCRIPT_DIR
# shellcheck disable=1091
. "${SCRIPT_DIR}/../libexec/climail/climail.inc.sh"

usage_exit() {
	echo "$(gettext 'Usage'): $0 [<search_pattern ...>]"
	exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	--)
		shift; break ;;
	--help)
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
done

select_command=(
	fzf
	"--border-label= $(gettext 'Select mail folder') "
	"--height=~100%"
	"--highlight-line"
	"--info=right"
	"--keep-right"
	"--no-multi"
	"--tmux=center,50,80%"
)

[[ $# -ge 1 ]] && select_command+=(
	"--select-1"
	"-q"
	"${@}"
)

while
	folder=$("${SCRIPT_DIR}"/lister |
		sed -e 's/^+.//' -e 's/^+$/INBOX/' |
		"${select_command[@]}"
	)
do
	if [[ "${folder}" = "INBOX" ]]; then
		mailbox="+"
	else
		mailbox="+.${folder}"
	fi
	"${SCRIPT_DIR}"/openmail "${mailbox}" || exit $?
	[[ $# -ge 1 ]] && exit 0
	echo
done
