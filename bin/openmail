#!/usr/bin/env bash
#
# climail/openmail:
# Setup and call an email client for a Maildir folder.
#

set -euo pipefail

# shellcheck disable=SC1091
. gettext.sh
export TEXTDOMAIN=climail
for locale_dir in ./po /usr/local/share/locale; do
	if [[ -r "${locale_dir}/de/LC_MESSAGES/climail.mo" ]]; then
		export TEXTDOMAINDIR=$locale_dir
		break
	fi
done

export PAGER=${CLIMAIL_PAGER:-${PAGER:-more}}
export LISTER=${LISTER:-"$(dirname "$0")"/lister}

usage_exit() {
	echo "$(gettext 'Usage'): $0 [<mailbox> [<mailbox_command> [<arguments...>]]]"
	exit "${1:-0}"
}

get_mailbox_name() {
	if [[ "$1" = "+" ]]; then
		echo "INBOX"
	else
		echo "${1#+.}"
	fi
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

mailbox="${1:-+}"
[[ $# -ge 1 ]] && shift

# Translate folder name into proper mailbox name:
case "${mailbox}" in
"INBOX"|"inbox")
	mailbox="+" ;;
.*)
	# Leading "+" missing!?
	mailbox="+${mailbox}" ;;
[A-Za-z0-9]*)
	# Leading "+." missing!?
	mailbox="+.${mailbox}" ;;
esac

mailbox_command=("$@")

if [[ -z "${mailbox_command[0]:-}" ]]; then
	if command -v s-nail >/dev/null 2>&1; then
		mailbox_command=("s-nail" "-f")
	else
		mailbox_command=("mail" "-f")
	fi
fi

cmd=${mailbox_command[0]}
if ! command -v "${cmd}" >/dev/null 2>&1; then
	eval_gettext "Command not found: \"\${cmd}\"!"; echo
	exit 1
fi


# shellcheck disable=SC2034
mailbox_name="\e[1m$(get_mailbox_name "$mailbox")\e[0m"
# shellcheck disable=SC2016
echo -e "$(eval_gettext 'Opening "${mailbox_name}" with ${cmd}:')"

exec "${mailbox_command[@]}" "${mailbox}"
