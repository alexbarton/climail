#!/usr/bin/env bash
#
# climail/openmail:
# Setup and call an email client for a Maildir folder.
#

set -euo pipefail

SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
export SCRIPT_DIR
# shellcheck disable=1091
. "${SCRIPT_DIR}/../libexec/climail/climail.inc.sh"

usage_exit() {
	echo "$(gettext 'Usage'): $0 [<mailbox> [<mailbox_command> [<arguments...>]]]"
	exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
	case "$1" in
	"--help")
		usage_exit 0 ;;
	-*)
		usage_exit 1 >&2 ;;
	*)
		break
	esac
	shift
done

mailbox="${1:-+}"
[[ $# -ge 1 ]] && shift

# Translate folder name into proper mailbox name:
case "${mailbox}" in
"INBOX"|"inbox")
	mailbox="+" ;;
.*)
	# Leading "+" missing!?
	mailbox="+${mailbox}" ;;
[A-Za-z0-9]*)
	# Leading "+." missing!?
	mailbox="+.${mailbox}" ;;
esac

mailbox_command=("$@")

if [[ -z "${mailbox_command[0]:-}" ]]; then
	if command -v s-nail >/dev/null 2>&1; then
		mailbox_command=("s-nail" "-f")
	else
		mailbox_command=("mail" "-f")
	fi
fi

# Update mailbox_command[0] with the fully qualified command, including its
# path, because next we will change the working directory to the temp directory
# to make sure that the mailbox command has a readable CWD even when called
# from a non-readable working directory (for example, when this script is
# called via sudo(8)):
cmd=${mailbox_command[0]}
if ! mailbox_command[0]=$(command -v "${cmd}" 2>/dev/null); then
	eval_gettext "Command not found: \"\${cmd}\"!"; echo
	exit 1
fi
cd "${TMPDIR:-/tmp}"

# shellcheck disable=SC2034
mailbox_name="\e[1m$(get_mailbox_name "$mailbox")\e[0m"
# shellcheck disable=SC2016
echo -e "$(eval_gettext 'Opening "${mailbox_name}" with ${cmd}:')"

exec "${mailbox_command[@]}" "${mailbox}"
